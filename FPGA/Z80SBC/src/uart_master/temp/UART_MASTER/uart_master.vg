module UART_MASTER_Top (
  I_CLK,
  I_RESETN,
  I_TX_EN,
  I_WADDR,
  I_WDATA,
  I_RX_EN,
  I_RADDR,
  O_RDATA,
  SIN,
  RxRDYn,
  SOUT,
  TxRDYn,
  DDIS,
  INTR,
  DCDn,
  CTSn,
  DSRn,
  RIn,
  DTRn,
  RTSn
)
;
input I_CLK;
input I_RESETN;
input I_TX_EN;
input [2:0] I_WADDR;
input [7:0] I_WDATA;
input I_RX_EN;
input [2:0] I_RADDR;
output [7:0] O_RDATA;
input SIN;
output RxRDYn;
output SOUT;
output TxRDYn;
output DDIS;
output INTR;
input DCDn;
input CTSn;
input DSRn;
input RIn;
output DTRn;
output RTSn;
wire VCC;
wire GND;
  \~uart_master.UART_MASTER_Top  i4 (
    .I_CLK(I_CLK),
    .I_RX_EN(I_RX_EN),
    .I_TX_EN(I_TX_EN),
